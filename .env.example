# Environment configuration (no secrets; replace with real values per environment)

APP_ENV=local
NODE_ENV=development

# Backend/API
API_BASE_URL=http://localhost:3000
SESSION_SECRET=changeme
APP_PORT=3000

# Database (Neon/Postgres)
NEON_DATABASE_URL=postgres://user:password@host:5432/dbname
NEON_CA_CERT_PATH=./certs/neon-ca.pem  # optional if using SSL
# Local dev (SQLite via Prisma)
DATABASE_URL="file:./prisma/dev.db"
PRISMA_CLIENT_ENGINE_TYPE=binary

# Content (Sanity)
SANITY_PROJECT_ID=your_project_id
SANITY_DATASET=production
SANITY_API_VERSION=2023-10-01
SANITY_READ_TOKEN=your_read_token

# Frontend
PUBLIC_APP_URL=http://localhost:3000
PUBLIC_LOCALE_DEFAULT=en-US

# Analytics (if applicable)
ANALYTICS_WRITE_KEY=your_write_key
EVENTS_INGEST_URL=http://localhost:4000/api/events  # stub ingestion

# Payments (placeholder for future marketplace)
PAYMENTS_PROVIDER_KEY=your_payments_key
PAYMENTS_WEBHOOK_SECRET=your_webhook_secret
